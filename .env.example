PORT=5000
DB_HOST=localhost
DB_USER=root
DB_PASSWORD=yourpassword
DB_NAME=assetflow
JWT_SECRET=change_this_secret
JWT_EXPIRES_IN=7d

# Optional. Leave blank to skip email verification (signup works instantly).
# Fill these in (e.g. Gmail SMTP + an "app password") to enable real
# verification-code emails and welcome emails.
EMAIL_HOST=
EMAIL_PORT=587
EMAIL_USER=
EMAIL_PASS=
EMAIL_FROM="AssetFlow <no-reply@assetflow.com>"
